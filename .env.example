# Local environment variables used by the VoiceForge Express server.
# Copy this file to .env and fill in the values before running `npm run dev`.
# No API key or paid plan is required — VoiceForge uses the free
# ResembleAI/Chatterbox-Multilingual-TTS space on Hugging Face.

CLIENT_URL=http://localhost:5173
PORT=3001

# ------------------------------------------------------------------
# VOICE_ENGINE_SPACE — optional Hugging Face Gradio space override
# ------------------------------------------------------------------
# Override the voice synthesis space if you fork or host your own copy.
# Leave commented out to use the default public production engine.
#
# VOICE_ENGINE_SPACE=ResembleAI/Chatterbox-Multilingual-TTS

# ------------------------------------------------------------------
# MOCK_CHATTERBOX — offline dev/CI mode (no Hugging Face calls needed)
# ------------------------------------------------------------------
# Set to "true" to skip all real Chatterbox network calls:
#   - POST /api/voice/clone  → returns a fixture voice_id instantly
#   - GET  /api/voice/speak/stream → streams a short silent MP3
#
# This lets you exercise the complete UI flow locally:
#   record → clone → type text → Speak → download audio
# without any internet access to Hugging Face.
#
# Safety: has NO effect when NODE_ENV=production (ignored automatically).
# ------------------------------------------------------------------
# MOCK_CHATTERBOX=true

# ------------------------------------------------------------------
# STREAM_SECRET — optional AES-256-GCM signing key for speech tokens
# ------------------------------------------------------------------
# Set to a long random string for stable speech tokens across server
# restarts. Leave blank to use an ephemeral per-process key (fine for
# local development but tokens are invalidated on each restart).
#
# STREAM_SECRET=replace_with_a_long_random_secret_string
